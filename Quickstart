#!/usr/bin/env bash

set -e
set -o nounset
set -o pipefail

export ENV="${ENV:-dev}"

if [[ -f ".env.${ENV}" ]]; then
    set -a
    . ".env.${ENV}"
    set +a
fi

if [[ "${TRACE-0}" == "1" ]]; then
    set -o xtrace
fi

log() {
    echo "[$(date +'%Y-%m-%d %H:%M:%S')] $*"
}

help_function() {
    cat <<EOF

Usage: $(basename "$0") [-h] [-c] [-u] [-p]

Description:
  Bootstrap the tensor-factory uv workspace and run the MCP detection server, or
  run the local quality gate.

Options:
  -h, --help        Display this help message and exit
  -c, --check       Run the full local gate: install -> lint+format -> types -> unit
  -u, --unit-test   Run unit tests only
  -p, --publish     Run the full gate, then build and publish to PyPI

With no options, bootstraps the workspace (uv sync) and starts the tensor-factory
MCP server with standard settings (bundled demo model, stdio) so you can try the
project immediately -- no flag required. Connect an MCP client via .mcp.json, e.g.
  { "mcpServers": { "tensor-factory": { "command": "uv",
      "args": ["run", "--package", "tensor-factory-mcp", "tensor-factory-mcp"] } } }

Note:
  - Requires uv (auto-installed if missing). Uses '.venv' if present.
  - The server needs no API keys or GPU; it ships a bundled int8 demo model.
  - Publishing needs UV_PUBLISH_TOKEN (or a configured index) in the environment.

EOF
}

command_exists() {
    type "$1" &> /dev/null
}

check_dependencies() {
    if ! command_exists "uv"; then
        log "uv not found. Installing..."
        curl -LsSf https://astral.sh/uv/install.sh | sh
        if [[ -f "$HOME/.local/bin/env" ]]; then
            . "$HOME/.local/bin/env"
        elif [[ -f "$HOME/.cargo/env" ]]; then
            . "$HOME/.cargo/env"
        fi
    fi
    return 0
}

validate_and_build() {
    log "Syncing workspace (locked)"
    if ! uv sync --locked --all-packages; then
        log "ERROR: uv sync failed (lockfile drift? run 'uv lock')"
        return 1
    fi

    log "Linting"
    if ! uv run ruff check --fix; then
        log "ERROR: ruff check failed"
        return 1
    fi

    log "Formatting"
    if ! uv run ruff format; then
        log "ERROR: ruff format failed"
        return 1
    fi

    log "Type-checking"
    if ! uv run ty check; then
        log "ERROR: ty type check failed"
        return 1
    fi

    return 0
}

bootstrap() {
    log "Bootstrapping workspace (uv sync --locked --all-packages)"
    if ! uv sync --locked --all-packages; then
        log "ERROR: uv sync failed (lockfile drift? run 'uv lock')"
        return 1
    fi
    return 0
}

run_server() {
    log "Starting tensor-factory MCP server (stdio, bundled demo model)"
    log "Connect an MCP client via .mcp.json; Ctrl-C to stop."
    exec uv run --package tensor-factory-mcp tensor-factory-mcp
}

test_unit() {
    log "Running unit tests..."
    # `python -m pytest` (not bare `uv run pytest`) pins the venv interpreter so a
    # pytest earlier on PATH can't shadow the locked one and lose the workspace deps.
    if ! uv run python -m pytest -m unit; then
        log "ERROR: Unit tests failed"
        return 1
    fi
    return 0
}

publish() {
    log "Building distributions"
    if ! uv build --all-packages; then
        log "ERROR: build failed"
        return 1
    fi

    log "Publishing to PyPI"
    if ! uv publish; then
        log "ERROR: publish failed"
        return 1
    fi
    return 0
}

main() {
    check_dependencies

    if [[ "$#" -eq 0 ]]; then
        bootstrap || { log "Bootstrap failed"; exit 1; }
        run_server  # exec's into the server; does not return
    fi

    while [[ "$#" -gt 0 ]]; do
        case "$1" in
            -h|--help)
                help_function
                exit 0
                ;;
            -c|--check)
                validate_and_build || { log "Validation failed"; exit 1; }
                test_unit || { log "Unit tests failed"; exit 1; }
                log "All checks passed."
                exit 0
                ;;
            -u|--unit-test)
                test_unit || { log "Unit tests failed"; exit 1; }
                exit 0
                ;;
            -p|--publish)
                validate_and_build || { log "Validation failed"; exit 1; }
                test_unit || { log "Unit tests failed"; exit 1; }
                publish || { log "Publish failed"; exit 1; }
                exit 0
                ;;
            *)
                echo "Unknown parameter passed: $1"
                help_function
                exit 1
                ;;
        esac
    done
}

main "$@"
